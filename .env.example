# ============================================================
#  AliDealsBot - configuration
#  Copy this file to ".env" and fill in your real values.
# ============================================================

# ---- AliExpress Affiliate (Open Platform / Portals) ----
# Get these from https://portals.aliexpress.com  ->  API settings
ALI_APP_KEY=
ALI_APP_SECRET=
# Your affiliate tracking ID (PID), created in the Portals dashboard
ALI_TRACKING_ID=
# Gateway. Default is the global IOP gateway; leave as-is unless told otherwise.
ALI_GATEWAY=https://api-sg.aliexpress.com/sync

# ---- Telegram ----
# Bot token from @BotFather
TG_BOT_TOKEN=
# Channel the bot posts to. Use @channelusername  OR  the numeric -100... id.
# The bot must be an ADMIN of that channel.
TG_CHANNEL=

# ---- Catalog / targeting ----
# Which storefront language/currency/country the deals are shown for.
TARGET_LANGUAGE=EN
TARGET_CURRENCY=ILS
SHIP_TO_COUNTRY=IL
# Comma-separated keywords to rotate through when pulling deals.
KEYWORDS=phone accessories,kitchen gadgets,home decor,smart watch,led lights,car accessories,tools
# Comma-separated AliExpress category IDs to also pull hot products from (optional).
CATEGORY_IDS=
# Only post products at/under this sale price (in TARGET_CURRENCY). Blank = no cap.
MAX_PRICE=120
# Only post products with at least this discount percent. Blank = no minimum.
MIN_DISCOUNT=40
# Minimum positive-rating (evaluate_rate) percent to keep a product. Blank = ignore.
MIN_RATING=85

# ---- Posting behaviour ----
# How many deals to post per run.
POSTS_PER_RUN=1
# Cron schedule for `npm start` (server time). Default: every 3 hours.
POST_CRON=0 */3 * * *
# Language for the generated caption: "he" (Hebrew) or "en".
CAPTION_LANG=he
# Seconds to wait between individual posts inside one run.
POST_DELAY_SECONDS=8
# How many product images to show per post. 1 = single photo. 2-4 = an album
# (sendMediaGroup) followed by the Buy button. Clamped to 1..4.
IMAGES_PER_POST=3
# Active hours (posts only go out when the local hour is in [start, end);
# end=24 means through 23:59). Evaluated in POST_TZ so it survives DST.
POST_WINDOW_START=8
POST_WINDOW_END=24
POST_TZ=Asia/Jerusalem
