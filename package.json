    "test:tg": "node src/index.js test-tg",
    "seed": "node src/index.js seed"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
